# App
APP_NAME=UNBLEmiSHED-AI
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Core runtime
REASONING_MODE=fast
MODEL_BACKEND=heuristic
MODEL_TIMEOUT_SECONDS=30
MODEL_MAX_RETRIES=0
MODEL_ROUTING_ENABLED=true
SELF_EVALUATION_ENABLED=false
STRICT_RESPONSE_MODE=false
DEFAULT_ANSWER_STYLE=relational

# Database (Render free + Supabase recommended)
DATABASE_DRIVER=postgres
POSTGRES_DSN=postgresql://postgres:<URLENCODED_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Local model (optional, keep empty on free server)
MODEL_VOLUME_PATH=/opt/models
LOCAL_MODEL_PATH=
LOCAL_MODEL_THREADS=8
LOCAL_MODEL_CONTEXT_SIZE=2048
LOCAL_MODEL_MAX_TOKENS=120

# Memory
MEMORY_TOP_K=2
MEMORY_MAX_SUMMARY_TOKENS=120
MEMORY_CONTEXT_MAX_TOKENS=120
MEMORY_LONG_TERM_EVERY_N_MESSAGES=5
MEMORY_DB_PATH=data/humoniod_memory.db

# Embedding
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_DIM=384
EMBEDDING_ENABLED=true

# Tooling
TOOL_EXECUTION_ENABLED=true
TOOL_MAX_TIMEOUT_SECONDS=2.0

# Safe web lookup
INTERNET_LOOKUP_ENABLED=true
INTERNET_LOOKUP_TIMEOUT_SECONDS=3.0
INTERNET_LOOKUP_MAX_RESULTS=3
INTERNET_LOOKUP_MAX_CHARS=420

# Privacy (recommended ON)
PRIVACY_REDACTION_ENABLED=true
PRIVACY_REMOVE_SENSITIVE_CONTEXT_KEYS=true
RELATIONSHIP_MEMORY_TEXT_ENABLED=false

# Runtime analyzer
ANALYZER_ENABLED=true
ANALYZER_FILE_PATH=data/runtime_analyzer.jsonl
ANALYZER_POLL_SECONDS=2.0
ANALYZER_REQUEST_DELTA_THRESHOLD=5
ANALYZER_LATENCY_DELTA_MS=40
ANALYZER_MAX_FILE_BYTES=524288
ANALYZER_MAX_RECORDS=800

# Auth/rate-limit (set in production)
AUTH_ENABLED=false
AUTH_MODE=api_key
AUTH_API_KEY_HEADER=x-api-key
AUTH_API_KEY=change-me
RATE_LIMIT_ENABLED=false
REQUESTS_PER_MINUTE=120

# Telemetry
TELEMETRY_ENABLED=true

# Optional OpenAI-compatible fallback (keep empty for llama-only)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=
